# globals: assrt
# vim:fileencoding=utf-8
#
# python_modulo.pyj
# Tests for Python-style modulo: result takes the sign of the divisor.
# python_modulo defaults to True; no __python__ import needed.

ae = assrt.equal
ok = assrt.ok

# ── Positive operands ────────────────────────────────────────────────────────
ae(7 % 3, 1)
ae(0 % 5, 0)
ae(6 % 3, 0)

# ── Negative dividend ────────────────────────────────────────────────────────
ae(-7 % 3, 2)
ae(-1 % 3, 2)
ae(-6 % 3, 0)

# ── Negative divisor ─────────────────────────────────────────────────────────
ae(7 % -3, -2)
ae(1 % -3, -2)
ae(6 % -3, 0)

# ── Both negative ────────────────────────────────────────────────────────────
ae(-7 % -3, -1)
ae(-1 % -3, -1)
ae(-6 % -3, 0)

# ── Floats ───────────────────────────────────────────────────────────────────
ae(-7.5 % 2, 0.5)
ae(7.5 % -2, -0.5)
ae(2.5 % 1, 0.5)

# ── Booleans (treated as numbers) ────────────────────────────────────────────
ae(5 % True, 0)
ae(False % 3, 0)

# ── Augmented `%=` ───────────────────────────────────────────────────────────
x = -7
x %= 3
ae(x, 2)

y = 7
y %= -3
ae(y, -2)

z = -7
z %= -3
ae(z, -1)

# ── Inside expressions ───────────────────────────────────────────────────────
ae((-7 % 3) + 10, 12)
ae(((-10) % 3) * 2, 4)

# ── Variables (not just literals) ────────────────────────────────────────────
a = -7
b = 3
ae(a % b, 2)

# ── BigInt (Python semantics already worked; regression guard) ───────────────
ae(BigInt(-7) % BigInt(3), BigInt(2))
ae(BigInt(7) % BigInt(-3), BigInt(-2))

# ── Custom __mod__ wins over numeric path ────────────────────────────────────
# python_modulo routes through ρσ_op_mod_ns which dispatches __mod__/__rmod__
# even without overload_operators.
class Mod:
    def __init__(self, v):
        self.v = v
    def __mod__(self, other):
        return 'mod-' + self.v + '-' + other

m = Mod('a')
ae(m % 'b', 'mod-a-b')
