# STATUS: ✓ WORKS (added in this release)

n = 3
n **= 2
ae(n, 9)

n = 2
n **= 10
ae(n, 1024)

n = 5
n **= 0
ae(n, 1)

n = 4
n **= 0.5
ae(n, 2)

# ── 31. Augmented assignment operators ───────────────────────────────────────
# STATUS: ✓ WORKS — +=, -=, *=, /=, //=, %=, &=, |=, ^=, <<=, >>=

n = 10
n += 5;  ae(n, 15)
n -= 3;  ae(n, 12)
n *= 2;  ae(n, 24)
n //= 5; ae(n, 4)
n %= 3;  ae(n, 1)
n |= 6;  ae(n, 7)   # 1 | 6 = 7
n &= 5;  ae(n, 5)   # 7 & 5 = 5
n ^= 3;  ae(n, 6)   # 5 ^ 3 = 6
n <<= 2; ae(n, 24)  # 6 << 2 = 24
n >>= 1; ae(n, 12)  # 24 >> 1 = 12

# ── 32. Starred assignment ───────────────────────────────────────────────────
# STATUS: ✓ WORKS

a, *b, c = [1, 2, 3, 4, 5]
ae(a, 1)
ade(b, [2, 3, 4])
ae(c, 5)

# ── 33. match / case ─────────────────────────────────────────────────────────
# STATUS: ✓ WORKS

def _classify(x):
    match x:
        case 0:
            return 'zero'
        case 1:
            return 'one'
        case _:
            return 'other'

ae(_classify(0), 'zero')
ae(_classify(1), 'one')
ae(_classify(5), 'other')

# ── 34. dict.fromkeys() ──────────────────────────────────────────────────────
# STATUS: ✓ WORKS

from __python__ import dict_literals
ade(dict.fromkeys(['a', 'b'], 0), {'a': 0, 'b': 0})

# ── 35. @classmethod / @staticmethod ─────────────────────────────────────────
# STATUS: ✓ WORKS

class _Counted:
    _n = 0
    @classmethod
    def bump(cls):
        cls._n += 1
    @classmethod
    def count(cls):
        return cls._n

_Counted.bump()
_Counted.bump()
ae(_Counted.count(), 2)

class _Util:
    @staticmethod
    def add(a, b):
        return a + b

ae(_Util.add(3, 4), 7)

# ── 36. yield from ───────────────────────────────────────────────────────────
# STATUS: ✓ WORKS

def _sub():
    yield 10
    yield 20

def _outer():
    yield from _sub()
    yield 30

ade(list(_outer()), [10, 20, 30])

# ── 37. lambda keyword ───────────────────────────────────────────────────────
# STATUS: ✓ WORKS — compiles to anonymous JS function expression

double = lambda x: x * 2
ae(double(3), 6)
ae(double(0), 0)

add = lambda a, b: a + b
ae(add(2, 3), 5)

ae((lambda: 42)(), 42)

abs_val = lambda x: x if x >= 0 else -x
ae(abs_val(-5), 5)
ae(abs_val(3),  3)

greet = lambda name='world': 'hello ' + name
ae(greet(),        'hello world')
ae(greet('there'), 'hello there')

# lambda captures enclosing scope
def _make_adder(n):
    return lambda x: x + n

add10 = _make_adder(10)
ae(add10(5), 15)

# ── 38. Operator overloading (__add__, __sub__, etc.) ────────────────────────
# STATUS: ✓ WORKS — requires `from __python__ import overload_operators`

def _test_operator_overloading():
    from __python__ import overload_operators

    class Vec:
        def __init__(self, x, y):
            self.x = x
            self.y = y
        def __add__(self, other):
            return Vec(self.x + other.x, self.y + other.y)
        def __sub__(self, other):
            return Vec(self.x - other.x, self.y - other.y)
        def __mul__(self, n):
            return Vec(self.x * n, self.y * n)
        def __eq__(self, other):
            return self.x == other.x and self.y == other.y

    v1 = Vec(1, 2)
    v2 = Vec(3, 4)
    ok((v1 + v2) == Vec(4, 6))
    ok((v2 - v1) == Vec(2, 2))
    ok((v1 * 3)  == Vec(3, 6))

    class Num:
        def __init__(self, n):
            self.n = n
        def __neg__(self):
            return Num(-self.n)
        def __eq__(self, other):
            return self.n == other.n

    ok(-Num(5) == Num(-5))
    ok(-Num(-3) == Num(3))

    # Comparison dunders defined — called directly (< > <= >= are NOT re-dispatched)
    class Version:
        def __init__(self, n):
            self.n = n
        def __lt__(self, other):
            return self.n < other.n
        def __le__(self, other):
            return self.n <= other.n
        def __gt__(self, other):
            return self.n > other.n
        def __ge__(self, other):
            return self.n >= other.n

    v1 = Version(1)
    v2 = Version(2)
    ok(v1.__lt__(v2))
    ok(v2.__gt__(v1))
    ok(v1.__le__(Version(1)))
    ok(v2.__ge__(Version(2)))

    # __floordiv__ and __mod__
    class Int:
        def __init__(self, n):
            self.n = n
        def __floordiv__(self, other):
            return Int(Math.floor(self.n / other.n))
        def __mod__(self, other):
            return Int(self.n % other.n)
        def __eq__(self, other):
            return self.n == other.n

    ok(Int(7) // Int(2) == Int(3))
    ok(Int(7) % Int(3)  == Int(1))

_test_operator_overloading()

# ── 39. Nested comprehensions (multi-for) ────────────────────────────────────
# STATUS: ✓ WORKS

# Flatten nested list
ade([x for row in [[1,2],[3,4]] for x in row], [1,2,3,4])

# Filter within nested comprehension
ade([x for row in [[1,2,3],[4,5,6]] for x in row if x % 2 == 0], [2,4,6])

# Nested list comprehension — column extraction
matrix = [[1,2,3],[4,5,6],[7,8,9]]
ade([row[0] for row in matrix], [1,4,7])

# Three-level nesting
ade([i+j+k for i in [1] for j in [10] for k in [100]], [111])

# Dict comprehension over pairs
ade({k: v for k, v in [['a',1],['b',2]]}, {'a':1, 'b':2})

# Set comprehension with two for-clauses
ok({x+y for x in [1,2] for y in [10,20]} == {11, 12, 21, 22})

# ── 40. __bool__ semantic difference ─────────────────────────────────────────
# STATUS: ✗ SEMANTIC DIFFERENCE — empty list/dict are truthy in JS.
#         RapydScript does not dispatch to __bool__; JS truthiness applies.
# SKIP:
#   ok(not [])   # Python: True; RapydScript: FAILS ([] is truthy in JS)
#   ok(not {})   # Python: True; RapydScript: FAILS ({} is truthy in JS)
#
# Workaround: test len() == 0
ok(len([]) == 0)
ok(len({}) == 0)

# ── 41. __call__ as callable dispatch ────────────────────────────────────────
# STATUS: ✗ NOT SUPPORTED — callable() recognises __call__, but obj()
#         does not dispatch to __call__; use obj.__call__() explicitly.
# SKIP (calling obj() when __call__ is defined raises a TypeError):
#   class _Adder:
#       def __init__(self, n):
#           self.n = n
#       def __call__(self, x):
#           return self.n + x
#   add5 = _Adder(5)
#   ae(add5(3), 8)   # NOT supported — obj() does not invoke __call__
#
# Workaround: call __call__ directly

class _Adder:
    def __init__(self, n):
        self.n = n
    def __call__(self, x):
        return self.n + x

add5 = _Adder(5)
ae(add5.__call__(3),  8)   # explicit call works
ae(callable(add5), True)   # callable() still detects it (§7 above)

