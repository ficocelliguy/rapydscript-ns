# ── 61. Positional-only parameters def f(a, /, b): ────────────────────────────
# STATUS: ✓ WORKS — tested in test/starargs.pyj

def _po(a, b, /):
    return [a, b]

ade(_po(1, 2), [1, 2])

def _po_mix(a, /, b):
    return [a, b]

ade(_po_mix(1, 2),   [1, 2])
ade(_po_mix(1, b=2), [1, 2])

# ── 62. Keyword-only parameters def f(a, *, b): ───────────────────────────────
# STATUS: ✓ WORKS — tested in test/starargs.pyj

def _ko(a, *, b):
    return [a, b]

ade(_ko(1, b=2),   [1, 2])
ade(_ko(b=2, a=1), [1, 2])
