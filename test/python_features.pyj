# ── 31. Augmented assignment operators ───────────────────────────────────────
# STATUS: ✓ WORKS — +=, -=, *=, /=, //=, %=, &=, |=, ^=, <<=, >>=

n = 10
n += 5;  ae(n, 15)
n -= 3;  ae(n, 12)
n *= 2;  ae(n, 24)
n //= 5; ae(n, 4)
n %= 3;  ae(n, 1)
n |= 6;  ae(n, 7)   # 1 | 6 = 7
n &= 5;  ae(n, 5)   # 7 & 5 = 5
n ^= 3;  ae(n, 6)   # 5 ^ 3 = 6
n <<= 2; ae(n, 24)  # 6 << 2 = 24
n >>= 1; ae(n, 12)  # 24 >> 1 = 12

