# STATUS: ✓ WORKS

def _classify(x):
    match x:
        case 0:
            return 'zero'
        case 1:
            return 'one'
        case _:
            return 'other'

ae(_classify(0), 'zero')
ae(_classify(1), 'one')
ae(_classify(5), 'other')

