# ── 25. Generator .throw() ───────────────────────────────────────────────────
# STATUS: ✓ WORKS

def _gen_throw():
    try:
        yield 1
    except ValueError as e:
        yield 'caught'

g = _gen_throw()
ae(g.next().value, 1)
ae(g.throw(ValueError('err')).value, 'caught')

# ── 26. Generator .send() ────────────────────────────────────────────────────
# STATUS: ✓ WORKS

def _gen_send():
    data = yield 1
    yield data

g = _gen_send()
ae(g.next().value,    1)
ae(g.next('hello').value, 'hello')

