# ── 35. @classmethod / @staticmethod ─────────────────────────────────────────
# STATUS: ✓ WORKS

class _Counted:
    _n = 0
    @classmethod
    def bump(cls):
        cls._n += 1
    @classmethod
    def count(cls):
        return cls._n

_Counted.bump()
_Counted.bump()
ae(_Counted.count(), 2)

class _Util:
    @staticmethod
    def add(a, b):
        return a + b

ae(_Util.add(3, 4), 7)

