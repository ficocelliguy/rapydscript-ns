{
  "name": "rapydscript-ng",
  "description": "Pythonic JavaScript that doesn't suck",
  "homepage": "https://github.com/kovidgoyal/rapydscript-ng",
  "keywords": [
    "javascript",
    "rapydscript",
    "language",
    "compiler"
  ],
  "main": "tools/compiler.js",
  "scripts": {
    "test": "node bin/rapydscript self --complete --test && npm run test:unit && npm run test:ls",
    "test:unit": "node test/unit/index.js",
    "test:ls": "node test/unit/run-language-service.js",
    "start": "node bin/rapydscript",
    "build-self": "node bin/rapydscript self --complete",
    "build:ls": "node tools/build-language-service.js",
    "build": "rm -rf **/*pyj-cached dev && node bin/rapydscript self --complete && node bin/web-repl-export web-repl && node tools/build-language-service.js"
  },
  "version": "0.7.22",
  "license": "BSD-2-Clause",
  "engines": {
    "node": ">=0.12.0"
  },
  "maintainers": [
    {
      "name": "Kovid Goyal",
      "email": "kovid@kovidgoyal.net"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kovidgoyal/rapydscript-ng.git"
  },
  "dependencies": {
    "regenerator": ">= 0.12.1",
    "uglify-js": ">= 3.0.15"
  },
  "optionalDependencies": {
    "v8-profiler": ">= 5.2.9"
  },
  "bin": {
    "rapydscript": "bin/rapydscript"
  }
}
